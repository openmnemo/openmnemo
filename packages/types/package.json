{
  "name": "@openmnemo/types",
  "version": "0.3.0",
  "type": "module",
  "description": "Shared TypeScript types for OpenMnemo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmnemo/openmnemo.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/openmnemo/openmnemo#readme",
  "author": "OpenMnemo Contributors",
  "license": "MIT",
  "keywords": [
    "openmnemo",
    "memory",
    "transcript",
    "types",
    "ai"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
