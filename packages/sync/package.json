{
  "name": "@openmnemo/sync",
  "version": "0.2.1",
  "type": "module",
  "description": "Heartbeat daemon, config management, and background sync for OpenMnemo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmnemo/openmnemo.git",
    "directory": "packages/sync"
  },
  "homepage": "https://github.com/openmnemo/openmnemo#readme",
  "author": "OpenMnemo Contributors",
  "license": "MIT",
  "keywords": [
    "openmnemo",
    "memory",
    "sync",
    "heartbeat",
    "daemon"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openmnemo/core": "workspace:*",
    "@openmnemo/report": "workspace:*",
    "@openmnemo/types": "workspace:*",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
