{
  "name": "@openmnemo/report",
  "version": "0.4.1",
  "type": "module",
  "description": "OpenMnemo report generation — builds a static HTML dashboard from Memory/",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmnemo/openmnemo.git",
    "directory": "packages/report"
  },
  "homepage": "https://github.com/openmnemo/openmnemo#readme",
  "author": "OpenMnemo Contributors",
  "license": "MIT",
  "keywords": [
    "openmnemo",
    "memory",
    "report",
    "html",
    "dashboard"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openmnemo/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "@anthropic-ai/sdk": "^0.79.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.79.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  }
}
