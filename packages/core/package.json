{
  "name": "@openmnemo/core",
  "version": "0.4.1",
  "type": "module",
  "description": "Transcript parsing, import, dedup, indexing, and recall for OpenMnemo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/openmnemo/openmnemo.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/openmnemo/openmnemo#readme",
  "author": "OpenMnemo Contributors",
  "license": "MIT",
  "keywords": [
    "openmnemo",
    "memory",
    "transcript",
    "parser",
    "sqlite",
    "ai"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openmnemo/types": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "fast-glob": "^3.3.3",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
